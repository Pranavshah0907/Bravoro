# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

node_modules
dist
dist-ssr
*.local

# Editor directories and files
.vscode/*
!.vscode/extensions.json
.idea
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Environment variables — never commit
.env
.env.local
.env.production
.env.staging
.env.development
# Allow the example template
!.env.example

# Claude Code project metadata
.claude/

# MCP server config (contains API keys)
.mcp.json


# Temporary screenshots (generated files)
temporary screenshots/
temporary\ screenshots/

# Windows OS junk
desktop.ini
**/desktop.ini

# Screenshot utility scripts (local dev only)
screenshot.mjs
take-screenshot.mjs

# Supabase temp files
supabase/.temp/

# Migration data (one-time migration scripts, not part of the app)
migration_data/

# Sensitive credential files
InputFiles/*.json

# Session handoff docs (high-risk: chat transcripts with env dumps, keep local only)
docs/superpowers/plans/*-SESSION-HANDOFF.md

# Tool-output directories (may capture session state, tokens, or sensitive page snapshots)
.auth/
.playwright-mcp/
.superpowers/
.vercel/


# Local dev notes (secrets, scratch)
.dev-notes/
